rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    match /counters/{counterId} {
      allow read, write: if isSignedIn();
    }
    
    match /employees/{employeeId} {
      // Qualquer usuário autenticado pode ler os perfis (necessário para a lista de usuários)
      // e criar novos usuários (cadastro).
      allow read, create: if isSignedIn();

      // Um usuário pode atualizar o próprio perfil ou um administrador pode atualizar qualquer perfil.
      allow update: if isSignedIn();

      // Apenas administradores podem deletar usuários.
      allow delete: if false; // Deleção desabilitada por segurança por enquanto
    }

    match /tools/{toolId} {
      allow read, write: if isSignedIn();
    }

    match /{document=**} {
      allow read, write: if isSignedIn();
    }
  }
}
