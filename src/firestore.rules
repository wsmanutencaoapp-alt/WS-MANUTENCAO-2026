
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Busca dados do usuário SEMPRE no banco (default), independente de qual banco a regra está rodando
    function getUserData() {
      return get(/databases/(default)/documents/employees/$(request.auth.uid)).data;
    }

    function isAdmin() {
      let userPath = /databases/(default)/documents/employees/$(request.auth.uid);
      return request.auth != null && (
        request.auth.uid == 'SOID8C723XUmlniI3mpjBmBPA5v1' || 
        (exists(userPath) && get(userPath).data.accessLevel == 'Admin')
      );
    }
    
    function hasPermission(module) {
      if (!isAuthenticated()) return false;
      if (isAdmin()) return true;
      let userPath = /databases/(default)/documents/employees/$(request.auth.uid);
      return exists(userPath) && get(userPath).data.permissions[module] == true;
    }
    
    function isOwner(userId) {
        return request.auth.uid == userId;
    }

    // --- REGRAS PARA O BANCO TÉCNICO (aircraftModels, etc) ---
    match /aircraftModels/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /engineModels/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /apuModels/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /propellerModels/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /maintenance_tasks/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // --- REGRAS DO BANCO DEFAULT ---
    match /vehicles/{vehicleId} {
      allow get: if true;
      allow list: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /employees/{employeeId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isOwner(employeeId);
    }

    match /activities/{activityId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow update: if isAuthenticated();
        allow delete: if isAdmin();
    }

    match /{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
