
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/employees/$(request.auth.uid)).data;
    }

    function isAdmin() {
      // An admin is a user with Admin level.
      return exists(/databases/$(database)/documents/employees/$(request.auth.uid)) &&
             getUserData().accessLevel == 'Admin';
    }
    
    function hasPermission(module) {
      let userData = getUserData();
      // An admin has all permissions.
      // A regular user must be active and have the specific permission flag.
      return isAdmin() || (exists(/databases/$(database)/documents/employees/$(request.auth.uid)) && userData.permissions[module] == true && userData.status == 'Ativo');
    }

    match /supplies/{supplyId} {
      allow read: if isAuthenticated();
      allow write: if hasPermission('suprimentos');
    }
    
    match /tools/{toolId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if hasPermission('ferramentaria');
      
      match /calibration_history/{calibrationId} {
        allow read: if hasPermission('ferramentaria');
        allow create, write: if hasPermission('ferramentaria');
      }
    }
    
    match /kits/{kitId} {
      allow read: if isAuthenticated();
      allow write: if hasPermission('ferramentaria');
    }
    
    match /suppliers/{supplierId} {
      allow read: if hasPermission('compras');
      allow write: if hasPermission('compras');
    }
    
    match /operation_records/{operationRecordId} {
      allow read, write: if isAdmin();
    }
    
    match /images/{imageId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    match /employees/{employeeId} {
      allow read: if isAuthenticated();
      
      allow create: if request.auth.uid == employeeId;
      
      allow update: if isAdmin() || 
                     (request.auth.uid == employeeId && 
                      !('accessLevel' in request.resource.data) &&
                      !('permissions' in request.resource.data) &&
                      !('status' in request.resource.data));
    }
    
    match /expenses/{expenseId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if hasPermission('financeiro');
    }

    match /tool_requests/{requestId} {
      // Allow a user to create their own request.
      allow create: if isAuthenticated() && request.resource.data.requesterId == request.auth.uid;
      
      // Allow a user to read their own requests. Ferramentaria/Admins can read all.
      allow read: if (isAuthenticated() && (request.auth.uid == resource.data.requesterId || request.auth.uid == resource.data.handledBy)) || hasPermission('ferramentaria');
      
      // Allow Ferramentaria/Admins to update any request. A user can only cancel their own PENDING request.
      allow update: if hasPermission('ferramentaria') ||
                     (isAuthenticated() && request.auth.uid == resource.data.requesterId && resource.data.status == 'Pendente' && request.resource.data.status == 'Cancelada');

      // Only Admins can delete requests.
      allow delete: if isAdmin();
    }
    
    match /budgets/{budgetId} {
      allow read: if isAuthenticated();
      allow write: if hasPermission('financeiro');
    }
    
    match /addresses/{addressId} {
        allow read, write: if hasPermission('cadastros_enderecos');
    }

    match /counters/{counterId} {
        allow read, write: if isAuthenticated();
    }
  }
}
