rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Permite que qualquer usuário autenticado leia todos os arquivos.
    // Isso é útil para exibir fotos de perfil de outros usuários.
    match /{allPaths=**} {
      allow read: if request.auth != null;
    }

    // Regras específicas para fotos de perfil
    match /profile_pictures/{userId} {
      // Permite que um usuário crie ou atualize sua própria foto de perfil.
      // O nome do arquivo deve corresponder ao UID do usuário.
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
