rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Public write for vehicle checkout selfies
    match /selfie_retirada/{fileName} {
      allow write: if true; // Allow anyone to upload a selfie for checkout
      allow read: if request.auth != null; // But only authenticated users can read them
    }

    // Default rule for all other paths requires authentication
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
