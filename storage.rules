rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Permite leitura e escrita em qualquer arquivo para qualquer usuário autenticado.
    // Esta é uma regra ampla para desenvolvimento, mas resolve problemas de permissão.
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
