rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // WARNING: This is a completely permissive rule set.
    // It allows anyone to read, write, and delete any data in your database.
    // This is intended for initial development and MUST be replaced with
    // secure rules before deploying to a production environment.
    match /{document=**} {
      allow read, write: if true;
    }
  }
}

    