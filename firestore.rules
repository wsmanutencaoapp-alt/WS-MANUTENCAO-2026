rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- REGRAS PARA O MÓDULO MONITOR (ADICIONADO) ---
    match /monitors/{id} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // --- REGRAS ORIGINAIS RESTAURADAS ---

    // Verifica se o usuário está logado
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // IMPORTANTE: Busca o perfil SEMPRE no banco (default)
    // A sintaxe /databases/(default)/documents/ é a única permitida para cross-db
    function isAdmin() {
      let profilePath = /databases/(default)/documents/employees/$(request.auth.uid);
      return isAuthenticated() && (
        request.auth.uid == 'SOID8C723XUmlniI3mpjBmBPA5v1' || 
        (exists(profilePath) && get(profilePath).data.accessLevel == 'Admin')
      );
    }
    
    // Verifica permissão consultando o banco (default)
    function hasPermission(module) {
      let profilePath = /databases/(default)/documents/employees/$(request.auth.uid);
      return isAuthenticated() && (
        isAdmin() || 
        (exists(profilePath) && get(profilePath).data.permissions[module] == true)
      );
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // --- REGRAS PARA O BANCO TÉCNICO (operation-manager) ---
    match /aircraftModels/{id} {
      allow read: if isAuthenticated();
      allow write: if hasPermission('cadastros_tecnica_modelos_update');
    }
    match /engineModels/{id} {
      allow read: if isAuthenticated();
      allow write: if hasPermission('cadastros_tecnica_modelos_update');
    }
    match /apuModels/{id} {
      allow read: if isAuthenticated();
      allow write: if hasPermission('cadastros_tecnica_modelos_update');
    }
    match /propellerModels/{id} {
      allow read: if isAuthenticated();
      allow write: if hasPermission('cadastros_tecnica_modelos_update');
    }
    match /maintenance_tasks/{id} {
      allow read: if isAuthenticated();
      allow write: if hasPermission('cadastros_tecnica_tarefas_update');
    }

    // --- REGRAS PARA O BANCO PADRÃO (default) E GERAIS ---
    match /vehicles/{vehicleId} {
      allow get: if true;
      allow list: if hasPermission('cadastros_veiculos_view') || hasPermission('portaria_controle_veiculos_view');
      allow create: if hasPermission('cadastros_veiculos_create');
      allow update: if hasPermission('cadastros_veiculos_update') || hasPermission('portaria_controle_veiculos_update');
      allow delete: if hasPermission('cadastros_veiculos_delete');
    }

    match /employees/{employeeId} {
      allow read: if isAuthenticated();
      allow create: if hasPermission('cadastros_funcionarios_create') || isOwner(employeeId);
      allow update: if hasPermission('cadastros_funcionarios_update') || isOwner(employeeId);
      allow delete: if hasPermission('cadastros_funcionarios_delete');
    }

    match /activities/{activityId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    match /purchase_requisitions/{requisitionId} {
      allow read: if isAuthenticated();
      allow write: if hasPermission('compras_requisicao_update') || hasPermission('compras_controle_update');
    }

    // Regra fallback para garantir que o restante do app continue funcionando
    match /{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}