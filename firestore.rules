rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- REGRAS PARA O MÓDULO MONITOR (ADICIONADO) ---
    match /monitors/{id} {
      allow read, write: if isAuthenticated();
    }

    // --- REGRAS PARA CONTADORES (ESSENCIAL PARA NOVOS ITENS) ---
    match /counters/{counterId} {
      allow read, write: if isAuthenticated();
    }

    // --- REGRAS ORIGINAIS RESTAURADAS E AMPLIADAS ---

    // Verifica se o usuário está logado
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // IMPORTANTE: Busca o perfil SEMPRE no banco (default)
    function isAdmin() {
      let profilePath = /databases/(default)/documents/employees/$(request.auth.uid);
      return isAuthenticated() && (
        request.auth.uid == 'SOID8C723XUmlniI3mpjBmBPA5v1' || 
        (exists(profilePath) && get(profilePath).data.accessLevel == 'Admin')
      );
    }
    
    // Verifica permissão consultando o banco (default)
    function hasPermission(module) {
      let profilePath = /databases/(default)/documents/employees/$(request.auth.uid);
      return isAuthenticated() && (
        isAdmin() || 
        (exists(profilePath) && get(profilePath).data.permissions[module] == true)
      );
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // --- CADASTROS TÉCNICOS ---
    match /aircraftModels/{id} {
        allow read: if isAuthenticated();
        allow write: if hasPermission('cadastros_tecnica_modelos');
    }
    match /engineModels/{id} {
        allow read: if isAuthenticated();
        allow write: if hasPermission('cadastros_tecnica_modelos');
    }
    match /apuModels/{id} {
        allow read: if isAuthenticated();
        allow write: if hasPermission('cadastros_tecnica_modelos');
    }
    match /propellerModels/{id} {
        allow read: if isAuthenticated();
        allow write: if hasPermission('cadastros_tecnica_modelos');
    }
    match /maintenance_tasks/{id} {
        allow read: if isAuthenticated();
        allow write: if hasPermission('cadastros_tecnica_tarefas');
    }

    // --- SUPRIMENTOS E FERRAMENTARIA (ADICIONADO ESPECIFICAMENTE) ---
    match /supplies/{id} {
        allow read: if isAuthenticated();
        allow write: if hasPermission('cadastros_suprimentos') || hasPermission('suprimentos_movimentacao');
        
        match /stock/{stockId} {
            allow read, write: if isAuthenticated();
        }
    }
    
    match /tools/{id} {
        allow read: if isAuthenticated();
        allow write: if hasPermission('cadastros_ferramentas') || hasPermission('ferramentaria_movimentacao');
        
        match /calibration_history/{historyId} {
            allow read, write: if isAuthenticated();
        }
    }
    
    match /kits/{id} {
        allow read: if isAuthenticated();
        allow write: if hasPermission('ferramentaria_kits');
    }

    match /supply_movements/{id} {
        allow read: if isAuthenticated();
        allow write: if hasPermission('suprimentos_movimentacao');
    }

    // --- OUTROS CADASTROS ---
    match /vehicles/{vehicleId} {
      allow get: if true;
      allow list: if hasPermission('cadastros_veiculos') || hasPermission('portaria_controle_veiculos_view');
      allow create: if hasPermission('cadastros_veiculos');
      allow update: if hasPermission('cadastros_veiculos') || hasPermission('portaria_controle_veiculos_update');
      allow delete: if hasPermission('cadastros_veiculos');
    }

    match /employees/{employeeId} {
      allow read: if isAuthenticated();
      allow create: if hasPermission('cadastros_funcionarios') || isOwner(employeeId);
      allow update: if hasPermission('cadastros_funcionarios') || isOwner(employeeId);
      allow delete: if hasPermission('cadastros_funcionarios');
      
      match /trainings/{id} {
          allow read, write: if isAuthenticated();
      }
      match /notifications/{id} {
          allow read, write: if isOwner(employeeId);
      }
    }

    match /activities/{activityId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    match /purchase_requisitions/{requisitionId} {
      allow read: if isAuthenticated();
      allow write: if hasPermission('compras_requisicao') || hasPermission('compras_controle');
      
      match /items/{itemId} {
          allow read, write: if isAuthenticated();
      }
    }

    // Regra fallback para garantir que o restante do app continue funcionando
    match /{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated(); // Tornando o write mais permissivo como era em versões antigas
    }
  }
}