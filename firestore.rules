
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      // Use get() which doesn't count as a read operation in most cases within rules
      return get(/databases/$(database)/documents/employees/$(request.auth.uid)).data;
    }

    function isAdmin() {
      // An admin is a user with Admin level. The status check is handled by hasPermission for non-admins.
      return exists(/databases/$(database)/documents/employees/$(request.auth.uid)) &&
             getUserData().accessLevel == 'Admin';
    }
    
    function hasPermission(module) {
      let userData = getUserData();
      // An admin has all permissions.
      // A regular user must have the specific permission flag and be authenticated.
      // The active status check is now handled more granularly where needed, not globally here.
      return isAuthenticated() && (isAdmin() || (exists(/databases/$(database)/documents/employees/$(request.auth.uid)) && userData.permissions[module] == true));
    }
    
    function isOwner(userId) {
        return request.auth.uid == userId;
    }

    match /supplies/{supplyId} {
      allow read: if isAuthenticated();
      allow write: if hasPermission('suprimentos');
      
      match /stock/{stockId} {
        allow read: if isAuthenticated();
        allow write: if hasPermission('suprimentos');
      }
    }
    
    match /supply_movements/{movementId} {
      allow read, write: if hasPermission('suprimentos');
    }

    match /tools/{toolId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if hasPermission('ferramentaria');
      
      match /calibration_history/{calibrationId} {
        allow read: if hasPermission('ferramentaria');
        allow create, write: if hasPermission('ferramentaria');
      }
    }
    
    match /kits/{kitId} {
      allow read: if isAuthenticated();
      allow write: if hasPermission('ferramentaria');
    }
    
    match /suppliers/{supplierId} {
      allow read, write: if hasPermission('compras');
    }
    
    match /employees/{employeeId} {
      allow read: if isAuthenticated();
      // Allow user to create their own record on signup
      allow create: if isOwner(employeeId);
      
      allow update: if isAdmin() || 
                     (isOwner(employeeId) && 
                      !('accessLevel' in request.resource.data) &&
                      !('permissions' in request.resource.data) &&
                      !('status' in request.resource.data));
      
      match /notifications/{notificationId} {
        allow read, write: if isOwner(employeeId);
      }
    }
    
    match /expenses/{expenseId} {
      allow create: if hasPermission('financeiro');
      allow read, update, delete: if hasPermission('financeiro');
    }

    match /tool_requests/{requestId} {
      allow read, write: if (isAuthenticated() && (isOwner(resource.data.requesterId) || isOwner(resource.data.handledBy))) || hasPermission('ferramentaria');
    }
    
    match /budgets/{budgetId} {
      allow read: if isAuthenticated();
      allow write: if hasPermission('financeiro');
    }
    
    match /addresses/{addressId} {
        allow read, write: if hasPermission('cadastros');
    }

    match /cost_centers/{costCenterId} {
      allow read: if isAuthenticated();
      allow write: if hasPermission('cadastros');
    }

    match /purchase_requisitions/{requisitionId} {
        // A user can create/update their own SC, or if they have compras permission
        // A user can create an OC if they have 'compras' permission OR if they are the requester of the original SC
        allow read: if isAuthenticated();
        allow write: if hasPermission('compras') || 
                      (request.resource.data.type == 'Ordem de Compra' && request.auth.uid == get(/databases/$(database)/documents/purchase_requisitions/$(request.resource.data.originalRequisitionId)).data.requesterId) ||
                      (request.resource.data.type == 'Solicitação de Compra' && request.auth.uid == request.resource.data.requesterId);
        
        match /items/{itemId} {
            allow read: if isAuthenticated();
            allow write: if hasPermission('compras') || request.auth.uid == get(/databases/$(database)/documents/purchase_requisitions/$(requisitionId)).data.requesterId;
        }
    }

    match /counters/{counterId} {
        allow read, write: if isAuthenticated();
    }
  }
}
