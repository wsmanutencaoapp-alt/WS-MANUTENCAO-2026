
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }
    
    function hasPermission(permission) {
      // User must be authenticated to have any permission.
      if (!isAuthenticated()) {
        return false;
      }
      
      // The employee document must exist. If not, deny permission.
      if (!exists(/databases/$(database)/documents/employees/$(request.auth.uid))) {
        return false;
      }
      
      // Now it's safe to get user data.
      let userData = get(/databases/$(database)/documents/employees/$(request.auth.uid)).data;
      
      // Admins have all permissions.
      if (userData.accessLevel == 'Admin') {
        return true;
      }
      
      // For non-admins, check if the permissions map exists and has the required permission.
      return userData.permissions != null && userData.permissions[permission] == true;
    }
    
    function isOwner(userId) {
        return request.auth.uid == userId;
    }

    // --- CADASTROS ---
    match /addresses/{addressId} {
      allow get, list: if hasPermission('cadastros_enderecos_view');
      allow create: if hasPermission('cadastros_enderecos_create');
      allow delete: if hasPermission('cadastros_enderecos_delete');
      // No update for addresses
    }
    
    match /cost_centers/{costCenterId} {
      allow get, list: if hasPermission('cadastros_centro_custo_view');
      allow create: if hasPermission('cadastros_centro_custo_create');
      allow update: if hasPermission('cadastros_centro_custo_update');
      allow delete: if hasPermission('cadastros_centro_custo_delete');
    }
    
    match /suppliers/{supplierId} {
      allow get, list: if hasPermission('cadastros_fornecedores_view');
      allow create: if hasPermission('cadastros_fornecedores_create');
      allow update: if hasPermission('cadastros_fornecedores_update');
      allow delete: if hasPermission('cadastros_fornecedores_delete');
    }
    
    // --- SUPRIMENTOS ---
    match /supplies/{supplyId} {
      allow get, list: if hasPermission('cadastros_suprimentos_view') || hasPermission('suprimentos_lista_view');
      allow create: if hasPermission('cadastros_suprimentos_create');
      allow update: if hasPermission('cadastros_suprimentos_update') || hasPermission('suprimentos_lista_update');
      allow delete: if hasPermission('cadastros_suprimentos_delete');
      
      match /stock/{stockId} {
        allow get, list: if hasPermission('suprimentos_lista_view');
        allow create: if hasPermission('suprimentos_movimentacao_create') || hasPermission('compras_controle_create');
        allow update: if hasPermission('suprimentos_lista_update');
        allow delete: if hasPermission('suprimentos_lista_delete');
      }
    }
    
    match /supply_movements/{movementId} {
      allow get, list: if hasPermission('suprimentos_movimentacao_view');
      allow create: if hasPermission('suprimentos_movimentacao_create') || hasPermission('compras_controle_create');
      // Immutable log
      allow update, delete: if false; 
    }

    // --- FERRAMENTARIA ---
    match /tools/{toolId} {
      allow get: if isAuthenticated();
      allow list: if hasPermission('cadastros_ferramentas_view') || hasPermission('ferramentaria_lista_view') || hasPermission('calibracao_view');
      allow create: if hasPermission('cadastros_ferramentas_create') || hasPermission('compras_controle_create');
      allow update: if hasPermission('cadastros_ferramentas_update') || hasPermission('ferramentaria_lista_update') || hasPermission('calibracao_update');
      allow delete: if hasPermission('cadastros_ferramentas_delete');
      
      match /calibration_history/{calibrationId} {
        allow get, list: if hasPermission('calibracao_view');
        allow create: if hasPermission('calibracao_create') || hasPermission('compras_controle_create');
        allow update: if hasPermission('calibracao_update');
        allow delete: if hasPermission('calibracao_delete');
      }
    }
    
    match /kits/{kitId} {
      allow get, list: if hasPermission('ferramentaria_kits_view');
      allow create: if hasPermission('ferramentaria_kits_create');
      allow update: if hasPermission('ferramentaria_kits_update');
      allow delete: if hasPermission('ferramentaria_kits_delete');
    }
    
    match /tool_requests/{requestId} {
      allow get, list: if hasPermission('ferramentaria_movimentacao_view');
      allow create: if hasPermission('ferramentaria_movimentacao_create');
      allow update: if hasPermission('ferramentaria_movimentacao_update') || (isOwner(resource.data.requesterId) && resource.data.status == 'Pendente');
      allow delete: if false; // Use update to set status to 'Cancelada'
    }

    // --- FINANCEIRO ---
    match /budgets/{budgetId} {
      allow get, list: if hasPermission('financeiro_budget_view');
      allow create: if hasPermission('financeiro_budget_create');
      allow update: if hasPermission('financeiro_budget_update');
      allow delete: if hasPermission('financeiro_budget_delete');
    }
    
    match /expenses/{expenseId} {
      allow get, list: if hasPermission('financeiro_despesas_view');
      allow create: if hasPermission('financeiro_despesas_create');
      allow update, delete: if false; // Log should be immutable
    }

    // --- COMPRAS ---
    match /purchase_requisitions/{requisitionId} {
        allow get, list: if hasPermission('compras_requisicao_view') || hasPermission('compras_aprovacoes_view') || hasPermission('compras_controle_view');

        allow create: if hasPermission('compras_requisicao_create') || hasPermission('compras_controle_create');

        allow update: if hasPermission('compras_requisicao_update') || hasPermission('compras_aprovacoes_update') || hasPermission('compras_controle_update');

        allow delete: if hasPermission('compras_requisicao_delete');
        
        match /items/{itemId} {
            allow get, list: if hasPermission('compras_requisicao_view') || hasPermission('compras_controle_view');
            allow create: if hasPermission('compras_requisicao_create');
            allow update: if hasPermission('compras_controle_update') || hasPermission('compras_requisicao_update');
            allow delete: if hasPermission('compras_requisicao_delete');
        }
    }

    // --- SISTEMA / ADMIN ---
    match /employees/{employeeId} {
      // Any authenticated user can read their own document.
      allow get: if isOwner(employeeId);
      
      // Only users with 'userManagement_view' can list all employees.
      allow list: if hasPermission('userManagement_view');

      // On sign up, a user can create their own document.
      allow create: if isOwner(employeeId);
      
      // Admin can update everything. User can update their own non-sensitive info.
      allow update: if hasPermission('userManagement_update') || (isOwner(employeeId) && !('accessLevel' in request.resource.data) && !('permissions' in request.resource.data) && !('status' in request.resource.data));

      allow delete: if false; // Never delete employee records
      
      match /notifications/{notificationId} {
        // Any authenticated user can create a notification for another user
        allow create: if isAuthenticated(); 
        allow read, update, delete: if isOwner(employeeId);
      }
    }
    
    match /counters/{counterId} {
        allow read, write: if isAuthenticated(); // Internal counters
    }

    match /email_configurations/{configId} {
      allow read: if isAuthenticated();
      allow write: if hasPermission('configurador_disparo_email_update');
    }
    
    // --- Engenharia ---
    match /engenharia/projetos/{projectId} {
       allow read, write: if hasPermission('engenharia_projetos_view');
    }
  }
}
