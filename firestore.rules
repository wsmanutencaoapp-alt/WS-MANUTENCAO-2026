rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      // Check if the user's UID exists in the employees collection and has the 'Admin' accessLevel.
      return exists(/databases/$(database)/documents/employees/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/employees/$(request.auth.uid)).data.accessLevel == 'Admin';
    }

    match /supplies/{supplyId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    match /tools/{toolId} {
      allow read: if isAuthenticated();
      // Allow create for any authenticated user, but restrict update/delete to admins.
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
      
      // Allow any authenticated user to create calibration history records (needed for new tool creation).
      match /calibration_history/{calibrationId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow write: if isAdmin();
      }
    }
    
    match /kits/{kitId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    match /suppliers/{supplierId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    match /operation_records/{operationRecordId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    match /images/{imageId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    match /employees/{employeeId} {
      allow read: if isAuthenticated();
      // Allow a user to edit their own data, or allow an admin to edit any user's data.
      allow write: if request.auth.uid == employeeId || isAdmin();
    }
    
    match /expenses/{expenseId} {
      // Allow any authenticated user to create an expense record.
      allow create: if isAuthenticated();
      // Only admins can read, update, or delete expense records.
      allow read, update, delete: if isAdmin();
    }

    match /tool_requests/{requestId} {
      // Allow a user to read/write their own requests, or allow an admin to manage all requests.
      allow read, write: if request.resource.data.requesterId == request.auth.uid || isAdmin();
    }
    
    match /budgets/{budgetId} {
      // Allow any authenticated user to read budgets (so sectors can see their budget).
      allow read: if isAuthenticated();
      // Only admins can create, update, or delete budget records.
      allow write: if isAdmin();
    }

    // This collection is used for generating sequential IDs.
    // Any authenticated user can read and write to it within a transaction.
    match /counters/{counterId} {
        allow read, write: if isAuthenticated();
    }
  }
}

    