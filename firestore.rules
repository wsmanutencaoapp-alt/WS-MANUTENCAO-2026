
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      // Use get() which doesn't count as a read operation in most cases within rules
      return get(/databases/$(database)/documents/employees/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return exists(/databases/$(database)/documents/employees/$(request.auth.uid)) &&
             getUserData().accessLevel == 'Admin';
    }
    
    function hasPermission(module) {
      let userData = getUserData();
      // An admin has all permissions.
      return isAuthenticated() && (isAdmin() || (userData.permissions[module] == true));
    }
    
    function isOwner(userId) {
        return request.auth.uid == userId;
    }

    // --- CADASTROS ---
    match /addresses/{addressId} {
      allow get, list: if isAuthenticated();
      allow create, update: if hasPermission('cadastros_enderecos');
      allow delete: if isAdmin();
    }
    
    match /cost_centers/{costCenterId} {
      allow get, list: if isAuthenticated();
      allow create, update: if hasPermission('cadastros_centro_custo');
      allow delete: if isAdmin();
    }
    
    match /suppliers/{supplierId} {
      allow get, list: if isAuthenticated();
      allow create, update: if hasPermission('cadastros_fornecedores');
      allow delete: if isAdmin();
    }
    
    // --- SUPRIMENTOS ---
    match /supplies/{supplyId} {
      allow get, list: if isAuthenticated();
      allow create, update: if hasPermission('cadastros_suprimentos');
      allow delete: if isAdmin();
      
      match /stock/{stockId} {
        allow get, list: if isAuthenticated();
        // Movements create/update stock lots
        allow create, update: if hasPermission('suprimentos'); 
        allow delete: if isAdmin();
      }
    }
    
    match /supply_movements/{movementId} {
      allow list: if hasPermission('suprimentos');
      allow get: if hasPermission('suprimentos');
      allow create: if hasPermission('suprimentos');
      allow update, delete: if isAdmin(); // Log should be immutable
    }

    // --- FERRAMENTARIA ---
    match /tools/{toolId} {
      allow get, list: if isAuthenticated();
      allow create, update: if hasPermission('cadastros_ferramentas') || hasPermission('ferramentaria') || hasPermission('calibracao');
      allow delete: if isAdmin();
      
      match /calibration_history/{calibrationId} {
        allow get, list: if hasPermission('calibracao') || hasPermission('ferramentaria');
        allow create: if hasPermission('calibracao');
        allow update, delete: if isAdmin();
      }
    }
    
    match /kits/{kitId} {
      allow get, list: if isAuthenticated();
      allow create, update: if hasPermission('ferramentaria_kits');
      allow delete: if hasPermission('ferramentaria_kits');
    }
    
    match /tool_requests/{requestId} {
      allow get: if isAuthenticated();
      allow list: if hasPermission('ferramentaria');
      allow create: if isOwner(request.resource.data.requesterId);
      allow update: if hasPermission('ferramentaria') || isOwner(resource.data.requesterId);
      allow delete: if isAdmin();
    }

    // --- FINANCEIRO ---
    match /budgets/{budgetId} {
      allow get, list: if isAuthenticated();
      allow create, update: if hasPermission('financeiro_budget');
      allow delete: if isAdmin();
    }
    
    match /expenses/{expenseId} {
      allow get, list: if hasPermission('financeiro');
      allow create: if hasPermission('financeiro_despesas');
      allow update, delete: if isAdmin();
    }

    // --- COMPRAS ---
    match /purchase_requisitions/{requisitionId} {
        allow get: if isAuthenticated();
        allow list: if hasPermission('compras');

        allow create: if isOwner(request.resource.data.requesterId);

        // Requester can cancel/update if it's in revision
        // Buyer can update for quotation
        // Approver can update status
        allow update: if (isOwner(resource.data.requesterId) && resource.data.status == 'Em Revisão') ||
                         hasPermission('compras') || hasPermission('compras_aprovacoes');

        allow delete: if isAdmin();
        
        match /items/{itemId} {
            allow get, list: if isAuthenticated();
            allow create, update: if hasPermission('compras') || isOwner(get(/databases/$(database)/documents/purchase_requisitions/$(requisitionId)).data.requesterId);
            allow delete: if hasPermission('compras') || isOwner(get(/databases/$(database)/documents/purchase_requisitions/$(requisitionId)).data.requesterId);
        }
    }

    // --- SISTEMA / ADMIN ---
    match /employees/{employeeId} {
      allow get, list: if hasPermission('userManagement');
      // On sign up
      allow create: if isOwner(employeeId);
      
      // A user can update their own non-sensitive info
      // An admin can update anything
      allow update: if isAdmin() || (isOwner(employeeId) && !('accessLevel' in request.resource.data) && !('permissions' in request.resource.data) && !('status' in request.resource.data));

      allow delete: if isAdmin();
      
      match /notifications/{notificationId} {
        allow read, update, delete: if isOwner(employeeId);
        // Any authenticated user can create a notification for another user
        allow create: if isAuthenticated(); 
      }
    }
    
    match /counters/{counterId} {
        allow read, write: if isAuthenticated();
    }

    match /email_configurations/{configId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
