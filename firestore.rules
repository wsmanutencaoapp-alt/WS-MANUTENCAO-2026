/**
 * @fileoverview Firestore Security Rules for AeroTrack's aircraft maintenance management system.
 *
 * Core Philosophy:
 * This ruleset enforces a data-centric security model, focusing on securing access to individual documents based on their content and relationships. It ensures that only authenticated users can access and modify data, with access often tied to the document's `employeeId` or other ownership-related fields.
 *
 * Data Structure:
 * The database consists of top-level collections for supplies, tools, suppliers, operation records, images, and employees.
 *
 * Key Security Decisions:
 * - All read and write operations require authentication.
 * - Listing operations are generally allowed for top-level collections, assuming no private user data is present.
 * - Data consistency is enforced through validation rules that ensure relationships between documents are maintained (e.g., `employeeId` in `OperationRecord` matches the authenticated user).
 * - The ruleset uses denormalization to optimize authorization checks, avoiding costly `get()` operations.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Manages access to aircraft maintenance supply items.
     * @path /supplies/{supplyId}
     * @allow (read): Authenticated users can read any supply item.
     * @allow (create): Authenticated users can create supply items.
     * @allow (update): Authenticated users can update supply items.
     * @allow (delete): Authenticated users can delete supply items.
     * @deny (create): Unauthenticated users cannot create supply items.
     * @deny (update): Unauthenticated users cannot update supply items.
     * @deny (delete): Unauthenticated users cannot delete supply items.
     * @principle Allows authenticated users to read and write supply data.
     */
    match /supplies/{supplyId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Manages access to aircraft maintenance tools and their calibration details.
     * @path /tools/{toolId}
     * @allow (read): Authenticated users can read any tool.
     * @allow (create): Authenticated users can create tools.
     * @allow (update): Authenticated users can update tools.
     * @allow (delete): Authenticated users can delete tools.
     * @deny (create): Unauthenticated users cannot create tools.
     * @deny (update): Unauthenticated users cannot update tools.
     * @deny (delete): Unauthenticated users cannot delete tools.
     * @principle Allows authenticated users to read and write tool data.
     */
    match /tools/{toolId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Manages access to supplier information.
     * @path /suppliers/{supplierId}
     * @allow (read): Authenticated users can read any supplier.
     * @allow (create): Authenticated users can create suppliers.
     * @allow (update): Authenticated users can update suppliers.
     * @allow (delete): Authenticated users can delete suppliers.
     * @deny (create): Unauthenticated users cannot create suppliers.
     * @deny (update): Unauthenticated users cannot update suppliers.
     * @deny (delete): Unauthenticated users cannot delete suppliers.
     * @principle Allows authenticated users to read and write supplier data.
     */
    match /suppliers/{supplierId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Manages access to operation records. Enforces that only the associated employee can create, update, or delete records.
     * @path /operation_records/{operationRecordId}
     * @allow (read): Authenticated users can read any operation record.
     * @allow (create): Only the employee specified in the record can create it.
     * @allow (update): Only the employee specified in the record can update it.
     * @allow (delete): Only the employee specified in the record can delete it, and only if the record exists.
     * @deny (create): An unauthenticated user cannot create operation records.
     * @deny (update): An unauthenticated user cannot update operation records.
     * @deny (delete): An unauthenticated user cannot delete operation records.
     * @principle Enforces employee-based ownership for operation records and validates relational integrity.
     */
    match /operation_records/{operationRecordId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.employeeId == request.auth.uid;
      allow update: if isSignedIn() && request.resource.data.employeeId == resource.data.employeeId && exists(resource);
      allow delete: if isSignedIn() && isExistingOwner(resource.data.employeeId);
    }

    /**
     * @description Manages access to images.
     * @path /images/{imageId}
     * @allow (read): Authenticated users can read any image.
     * @allow (create): Authenticated users can create images.
     * @allow (update): Authenticated users can update images.
     * @allow (delete): Authenticated users can delete images.
     * @deny (create): Unauthenticated users cannot create images.
     * @deny (update): Unauthenticated users cannot update images.
     * @deny (delete): Unauthenticated users cannot delete images.
     * @principle Allows authenticated users to read and write image data.
     */
    match /images/{imageId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    /**
     * @description Manages access to employee information.
     * @path /employees/{employeeId}
     * @allow (read): Authenticated users can read any employee.
     * @allow (create): Only the user with the matching ID can create their own employee document.
     * @allow (update): Authenticated users can update employee information.
     * @allow (delete): Authenticated users can delete employee information.
     * @deny (create): An unauthenticated user cannot create employee records.
     * @deny (update): An unauthenticated user cannot update employee records.
     * @deny (delete): An unauthenticated user cannot delete employee records.
     * @principle Allows authenticated users to read and write employee data.
     */
    match /employees/{employeeId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.id == request.auth.uid;
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    // --- Helper Functions ---

    /**
     * @description Checks if the user is signed in.
     * @return {bool} True if the user is signed in, false otherwise.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the user is the owner of the resource.
     * @param {string} userId The user ID to compare against.
     * @return {bool} True if the user is the owner, false otherwise.
     */
    function isOwner(userId) {
        return request.auth.uid == userId;
    }

    /**
     * @description Checks if the user is the existing owner of the resource and the resource exists.
     * @param {string} userId The user ID to compare against.
     * @return {bool} True if the user is the owner and the resource exists, false otherwise.
     */
    function isExistingOwner(userId) {
        return isOwner(userId) && exists(resource);
    }

    /**
     * @description Checks if a resource exists.
     * @param {Resource} resource The resource to check.
     * @return {bool} True if the resource exists, false otherwise.
     */
    function exists(resource) {
        return resource != null;
    }
  }
}