
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      // Use get() which doesn't count as a read operation in most cases within rules
      return get(/databases/$(database)/documents/employees/$(request.auth.uid)).data;
    }

    function isMasterAdmin() {
        return request.auth.token.email == 'grupodallax@gmail.com';
    }

    function isAdmin() {
      // An admin is either the master admin by email, or a user with Admin level and Active status.
      return isMasterAdmin() || 
             (exists(/databases/$(database)/documents/employees/$(request.auth.uid)) &&
             getUserData().accessLevel == 'Admin' && getUserData().status == 'Ativo');
    }
    
    function hasPermission(module) {
      let userData = getUserData();
      // An active admin has all permissions.
      // A regular user must be active and have the specific permission flag.
      return (isAdmin() || (exists(/databases/$(database)/documents/employees/$(request.auth.uid)) && userData.permissions[module] == true)) && userData.status == 'Ativo';
    }

    match /supplies/{supplyId} {
      allow read: if hasPermission('suprimentos');
      allow write: if hasPermission('suprimentos');
    }
    
    match /tools/{toolId} {
      allow read: if hasPermission('ferramentaria');
      // Create is limited to ferramentaria users
      allow create: if hasPermission('ferramentaria');
      // Update/delete is also limited to ferramentaria users
      allow update, delete: if hasPermission('ferramentaria');
      
      // Subcollection for calibration history
      match /calibration_history/{calibrationId} {
        allow read: if hasPermission('ferramentaria');
        allow create: if hasPermission('ferramentaria');
        allow write: if hasPermission('ferramentaria');
      }
    }
    
    match /kits/{kitId} {
      allow read: if hasPermission('ferramentaria');
      allow write: if hasPermission('ferramentaria');
    }
    
    match /suppliers/{supplierId} {
      allow read: if hasPermission('compras');
      allow write: if hasPermission('compras');
    }
    
    match /operation_records/{operationRecordId} {
      // Operation records could be sensitive, restricting to admins for now.
      allow read, write: if isAdmin();
    }
    
    match /images/{imageId} {
      allow read: if isAuthenticated();
      // Writing images is usually part of another process (like creating a tool),
      // so specific write rules are complex. Restricting to Admin is safest for now.
      allow write: if isAdmin();
    }
    
    match /employees/{employeeId} {
      allow read: if isAuthenticated();
      
      allow create: if request.auth.uid == employeeId;
      
      // The Master Admin can write to any employee document.
      // Any other user can only update their own profile, but cannot change critical fields.
      allow update: if isMasterAdmin() || 
                     (request.auth.uid == employeeId && 
                      !('accessLevel' in request.resource.data) &&
                      !('permissions' in request.resource.data) &&
                      !('status' in request.resource.data));
    }
    
    match /expenses/{expenseId} {
      // Allow user to create for themselves, but only finance/admin can read all
      allow create: if hasPermission('financeiro');
      allow read, update, delete: if hasPermission('financeiro');
    }

    match /tool_requests/{requestId} {
      // Allow a user to create/read/write their own requests if they are active.
      // Ferramentaria staff need to be able to read/update all requests.
      allow read, write: if (request.auth.uid == resource.data.requesterId && getUserData().status == 'Ativo') || hasPermission('ferramentaria');
    }
    
    match /budgets/{budgetId} {
      // Only users with finance permission can manage budgets.
      allow read, write: if hasPermission('financeiro');
    }
    
    match /addresses/{addressId} {
        // Any authenticated user can manage addresses as long as they are active.
        allow read, write: if isAuthenticated() && getUserData().status == 'Ativo';
    }

    // This collection is used for generating sequential IDs.
    // Any authenticated user can read and write to it within a transaction.
    match /counters/{counterId} {
        allow read, write: if isAuthenticated() && getUserData().status == 'Ativo';
    }
  }
}
